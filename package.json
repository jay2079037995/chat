{
  "name": "chat",
  "version": "1.25.0",
  "private": true,
  "description": "即时通讯应用 - Monorepo",
  "scripts": {
    "dev:client": "pnpm --filter @chat/client dev",
    "dev:server": "pnpm --filter @chat/server dev",
    "dev": "pnpm run dev:client & pnpm run dev:server",
    "dev:electron": "pnpm --filter @chat/electron dev",
    "dev:agent-renderer": "pnpm --filter @chat/agent-app dev:renderer",
    "dev:agent-main": "pnpm --filter @chat/agent-app dev:main",
    "build": "pnpm --filter @chat/shared build && pnpm --filter @chat/client build && pnpm --filter @chat/server build && pnpm --filter @chat/electron build && pnpm --filter @chat/agent-app build",
    "clean": "rm -rf packages/client/dist packages/server/dist packages/electron/dist packages/electron/release",
    "dist:mac": "pnpm run clean && pnpm run build && pnpm --filter @chat/electron dist:mac",
    "dist:agent-app": "pnpm --filter @chat/agent-app dist:mac",
    "test": "pnpm -r test",
    "test:ci": "bash scripts/test.sh",
    "test:env": "bash scripts/check-env.sh",
    "test:version": "bash scripts/test.sh --version",
    "test:e2e": "playwright test",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron"]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
