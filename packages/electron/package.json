  },
  "devDependencies": {
    "@types/extract-zip": "^2.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.6.0"
